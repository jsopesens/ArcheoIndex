:776 a owl:NamedIndividual,
        skos:Concept ;
    skos:broader :775 ;
    skos:broaderTransitive :765,
        :773,
        :775 ;
    skos:definition "(from anthrax (ἄνθραξ), the Greek word for coal) is the analysis and identification of charcoal from archaeological sites which is preserved after carbonization, based on wood anatomy."@en,
        "(de anthrax (ἄνθραξ), que significa carbón) es el análisis e identificación del carbón vegetal en sitios arqueológicos que se conserva después de la carbonización, basado en la anatomía de la madera."@es,
        "(du anthrax (ἄνθραξ), signifiant charbon) est l'analyse et l'identification du charbon de bois provenant de sites archéologiques, préservé après carbonisation, basée sur l'anatomie du bois."@fr ;
    skos:inScheme :764 ;
    skos:notation 776 ;
    skos:prefLabel "anthracology"@en,
        "antracología"@es,
        "anthracologie"@fr ;
    skos:related :813 ;
    skos:semanticRelation :765,
        :773,
        :775 .

